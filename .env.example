# Environment variables — DO NOT commit real values!
# Copy this file to .env and fill in your secrets.
# In RunPod, set these in the template's Environment Variables section.

# --- Tailscale ---
# Generate: https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTH_KEY=tskey-auth-xxxxxxxxxxxxxxxxx
TAILSCALE_HOSTNAME=runpod-llamacpp

# --- Model ---
# Path on network volume (mounted at /workspace by RunPod)
MODEL_PATH=/workspace/models/model.gguf

# Option A: Direct URL to GGUF file
MODEL_URL=

# Option B: HuggingFace Hub
HF_REPO=Qwen/Qwen2.5-32B-Instruct-GGUF
HF_FILE=qwen2.5-32b-instruct-q8_0.gguf
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# --- llama.cpp Server ---
HOST=0.0.0.0
PORT=8080
NGPULAYERS=99
ALIAS=llamacpp
CONTEXT=128000
THREADS=0
FLASH_ATTN=1
NO_MMAP=1

# Extra args (space-separated, passed directly to llama-server)
# Example: --no-context-shift --temp 0.7
LLAMACPP_EXTRA_ARGS=